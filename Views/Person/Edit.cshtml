@model Person
@{
    ViewData["Title"] = "Редактировать запись";
}

<h1>Редактировать именинника</h1>

@if (!string.IsNullOrEmpty(Model.PhotoPath))
{
<img src="@Model.PhotoPath" style="width:120px;height:120px;object-fit:cover;border-radius:8px;" class="mb-3" />
}

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="BirthDate" class="form-label"></label>
        <input asp-for="BirthDate" class="form-control" type="date" />
    </div>

    <div class="mb-3">
        <label asp-for="Note" class="form-label"></label>
        <textarea asp-for="Note" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Новое фото (необязательно)</label>
        <input type="file" name="photo" class="form-control" accept="image/*" />
    </div>

    <button type="submit" class="btn btn-success">Сохранить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>