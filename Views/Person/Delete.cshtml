@model Person
@{
    ViewData["Title"] = "Удалить запись";
}

<h1>Удалить запись?</h1>

<div class="card" style="max-width:400px;">
    @if (!string.IsNullOrEmpty(Model.PhotoPath))
    {
    <img src="@Model.PhotoPath" class="card-img-top" style="height:200px;object-fit:cover;" />
    }
    <div class="card-body">
        <h5>@Model.FullName</h5>
        <p>Дата рождения: @Model.BirthDate.ToString("dd.MM.yyyy")</p>
    </div>
</div>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-3">
    <button type="submit" class="btn btn-danger">Да, удалить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>