@model Person
@{
    ViewData["Title"] = "ƒобавить запись";
}

<h1>ƒобавить именинника</h1>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="BirthDate" class="form-label"></label>
        <input asp-for="BirthDate" class="form-control" type="date" />
        <span asp-validation-for="BirthDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Note" class="form-label"></label>
        <textarea asp-for="Note" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">‘ото</label>
        <input type="file" name="photo" class="form-control" accept="image/*" />
    </div>

    <button type="submit" class="btn btn-success">—охранить</button>
    <a asp-action="Index" class="btn btn-secondary">ќтмена</a>
</form>